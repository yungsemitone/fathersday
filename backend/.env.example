# Copy to ".env". Every section runs without any of these set — Markets falls
# back to sample data until you point it at your Stock Scraper backend.

# --- Markets: your Stock Scraper app's API base URL -------------------------
# Dev: the local backend. Prod: your deployed Fly URL (https://...).
STOCK_API_BASE=http://localhost:8000

# Optional: feature a specific one of Dad's watchlists by name (else the first).
FEATURED_WATCHLIST=

# The full Stock Dashboard UI (the Vercel frontend). When set, the Markets tab
# shows an "Open the full dashboard" button. This is the frontend URL, not the
# API above. Leave blank to hide the button.
STOCK_DASHBOARD_URL=

# Comma-separated allowed origins if the frontend is hosted separately.
# Not needed when this backend serves the frontend (same origin).
CORS_ORIGINS=*

# --- Wine: live K&L auctions via a Cloudflare unblocker service -----------
# K&L sits behind a Cloudflare challenge no server can pass directly. With a
# key here, the wine section pulls live K&L auction lots; without one, it uses
# the curated cellar (backend/data/wine_cellar.csv).
# provider: scraperapi | scrapingbee | scrapfly | zenrows
SCRAPER_PROVIDER=scraperapi
SCRAPER_API_KEY=
# Optional override of the auction page to read.
KL_AUCTION_URL=https://shop.klwines.com/products/auctions

# Set automatically by Fly (mounted volume). Leave blank locally.
DATA_DIR=
