# Copy to ".env". Every section runs without any of these set — Markets falls
# back to sample data until you point it at your Stock Scraper backend.

# --- Markets: your Stock Scraper app's API base URL -------------------------
# Dev: the local backend. Prod: your deployed Fly URL (https://...).
STOCK_API_BASE=http://localhost:8000

# Optional: feature a specific one of Dad's watchlists by name (else the first).
FEATURED_WATCHLIST=

# Comma-separated allowed origins if the frontend is hosted separately.
# Not needed when this backend serves the frontend (same origin).
CORS_ORIGINS=*

# Set automatically by Fly (mounted volume). Leave blank locally.
DATA_DIR=
